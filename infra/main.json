        "description": "azd environment name. Used for deterministic naming and tagging."
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Primary Azure region for this single-resource-group demo."
      }
    },
    "existingResourceGroupName": {
      "type": "string",
      "defaultValue": "",
