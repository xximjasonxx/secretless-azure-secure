  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "1599962836119391201"
    }
  },
  "parameters": {
    "environmentName": {
      "type": "string",
