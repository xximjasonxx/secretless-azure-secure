            },
            "addressPrefix": {
              "type": "string",
              "defaultValue": "10.42.0.0/16",
              "metadata": {
                "description": "Address space for the demo VNet."
              }
            },
            "appSubnetPrefix": {
              "type": "string",
              "defaultValue": "10.42.1.0/24",
              "metadata": {
                "description": "Address prefix for App Service integration subnet."
              }
            },
            "peSubnetPrefix": {
              "type": "string",
              "defaultValue": "10.42.2.0/24",
              "metadata": {
                "description": "Address prefix for private endpoint subnet."
              }
            }
          },
